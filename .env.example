# Port du serveur local (ignore sur Netlify)
PORT=3000

# Base de donnees libSQL.
#  - Local / dev : fichier SQLite local (zero config, aucun token requis)
DATABASE_URL=file:biblio.db

#  - Production (Turso) : decommenter et renseigner depuis le dashboard Turso.
#    Ces deux variables doivent etre definies dans Netlify > Site settings > Environment variables.
# DATABASE_URL=libsql://<votre-base>-<votre-org>.turso.io
# DATABASE_AUTH_TOKEN=<votre-token-turso>
